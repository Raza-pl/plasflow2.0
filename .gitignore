# Computed dataset arrays (regenerated by build_dataset.py)
data/features.npy
data/labels.npy
data/seq_ids.txt
data/dataset_stats.txt

# Test datasets — large genome files and computed outputs
data/test/*.fna
data/test/*.fa
data/test/*.fasta
data/test/*.predictions.tsv
data/test/*.fa.gz
data/test/*.fasta.bz2

# Results / outputs
results/
*.html          # don't commit generated reports
benchmarks/

